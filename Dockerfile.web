FROM node:20-bookworm-slim AS build

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

ARG VITE_PUBLIC_VIEWER_MODE=false
ENV VITE_PUBLIC_VIEWER_MODE=$VITE_PUBLIC_VIEWER_MODE

# Optional: override the default admin password hash (sha256 hex) baked into the
# bundle. Leave empty to keep the legacy default.
ARG VITE_ADMIN_PASSWORD_HASH=
ENV VITE_ADMIN_PASSWORD_HASH=$VITE_ADMIN_PASSWORD_HASH

RUN npm run build

FROM node:20-bookworm-slim AS runtime

ENV NODE_ENV=production
ENV PORT=5173

WORKDIR /app

RUN groupadd --system printfarm \
  && useradd --system --gid printfarm --home-dir /app printfarm

COPY package.json ./

# The server's runtime dependencies are the pg client and the mqtt client (used
# for Bambu printer commands). Keep these versions in sync with package.json.
# The build stage (npm ci) covers the rest.
RUN npm install pg@8.21.0 mqtt@5.15.1 --no-save --no-audit --no-fund \
  && npm cache clean --force

COPY --from=build /app/dist ./dist
COPY server ./server

USER printfarm

EXPOSE 5173

CMD ["node", "server/app.js"]
