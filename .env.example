POSTGRES_DB="printfarm"
POSTGRES_USER="printfarm_app"
POSTGRES_PASSWORD="replace_with_a_long_random_password"
HTTP_PORT="8080"
VITE_PUBLIC_VIEWER_MODE="false"
PRINTER_OFFLINE_GRACE_SECONDS="30"
PRINTER_POLL_INTERVAL_MS="2000"
PRINTER_REQUEST_TIMEOUT_MS="3000"
# The queue Google Sheet and print-request Google Form URLs are no longer set
# here. Configure them at runtime in Settings → Integrations (admin only);
# they are stored in the database.
