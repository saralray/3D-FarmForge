{
  "uid": "printfarm-status",
  "title": "Printer Status",
  "tags": ["printfarm"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Online",
      "description": "Printers that are not offline (matches the dashboard's Online count: status != 'offline').",
      "datasource": { "type": "prometheus", "uid": "printfarm-prometheus" },
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "printfarm-prometheus" },
          "expr": "sum(printfarm_printer_up) or vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "Online"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "unit": "none",
          "decimals": 0,
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value",
        "wideLayout": true,
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "showPercentChange": false
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Printing",
      "description": "Printers with status 'printing'.",
      "datasource": { "type": "prometheus", "uid": "printfarm-prometheus" },
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 0 },
